<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Windows-only: MonoGame.Framework.WindowsDX is a DX11 (Windows) runtime.
         Intentionally NOT in ShadowDusk.slnx so cross-platform builds never see it. -->
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <RootNamespace>ShadowDusk.Validation.Dx.VsDriven</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MonoGame.Framework.WindowsDX" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\ShadowDusk.Compiler\ShadowDusk.Compiler.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\SharedDx\DxEffectImageRenderer.cs" />
    <Compile Include="..\SharedDx\VsDxEffectImageRenderer.cs" />
  </ItemGroup>
</Project>
