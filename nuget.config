<?xml version="1.0" encoding="utf-8"?>
<!--
  Hermetic restore for ShadowDusk. The repo uses central package management
  (Directory.Packages.props); NuGet raises NU1507 (treated as an error here) when
  central package management is combined with more than one ambient package source,
  unless sources are reduced to one or mapped. With no repo-level config, restore
  falls through to the consumer's machine-level NuGet.Config, so any machine with an
  extra feed (e.g. a private GitHub Packages source) fails to build — including when
  ShadowDusk is consumed as a transitive ProjectReference from another repo, since
  NuGet resolves each project's config from its own folder tree.

  Pin restore to nuget.org and map every package to it (and clear inherited sources)
  so the build resolves identically regardless of machine-level feeds. All ShadowDusk
  dependencies are published on nuget.org, so this loses nothing.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
