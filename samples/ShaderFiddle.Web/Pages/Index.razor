@page "/"
@page "/index.html"
@inject IJSRuntime JsRuntime
@inject HttpClient Http

<PageTitle>ShadowDusk — Shader Fiddle (KNI WebGL)</PageTitle>

<div class="fiddle">

    <section class="controls">
        <h1>ShadowDusk Shader Fiddle</h1>
        <p class="tagline">
            Paste HLSL <code>.fx</code>, compile <strong>in the browser</strong>, see it on the cat.
            <a href="https://github.com/kaltinril/ShadowDusk" target="_blank">about</a>
        </p>

        <div class="row">
            <label for="corpus">Load a precompiled sample (mode&nbsp;1):</label>
            <select id="corpus" value="@_selected" @onchange="OnCorpusChanged" disabled="@(!_ready)">
                @foreach (var name in WebShaderInputs.ShaderNames)
                {
                    <option value="@name">@name</option>
                }
            </select>
        </div>

        <textarea class="editor" spellcheck="false" @bind="_source" @bind:event="oninput"></textarea>

        <div class="row buttons">
            <button class="primary" @onclick="CompileAndApplyAsync" disabled="@(!_ready || _compiling)">
                @(_compiling ? "Compiling…" : "Compile & Apply (mode 2)")
            </button>
            <button @onclick="ResetEffect" disabled="@(!_ready || _compiling)">
                Reset (no shader)
            </button>
            <span class="status @(_statusIsError ? "err" : "ok")">@_status</span>
        </div>

        @if (_params.Count > 0)
        {
            <div class="params">
                <div class="params-head">Live parameters — edit to drive the shader</div>
                @foreach (var p in _params)
                {
                    <div class="param-row">
                        <span class="pname" title="@p.Name">@p.Name</span>
                        <div class="pvals">
                            @for (var i = 0; i < p.Components; i++)
                            {
                                var idx = i;
                                <input type="number" step="0.01" class="pval"
                                       value="@p.Values[idx].ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       @onchange="@(e => OnParamChanged(p, idx, e))" />
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @if (_errors.Count > 0)
        {
            <div class="errors">
                <div class="errors-head">@_errors.Count diagnostic(s)</div>
                @foreach (var d in _errors)
                {
                    <pre class="diag">@d</pre>
                }
            </div>
        }

        <details class="note">
            <summary>How does "Compile & Apply" work?</summary>
            <p>
                It compiles the <code>.fx</code> in the editor <strong>entirely in the
                browser</strong> via <code>WasmShaderCompiler</code> — the faithful
                HLSL&nbsp;→&nbsp;DXC&nbsp;(WASM)&nbsp;→&nbsp;SPIR-V&nbsp;→&nbsp;SPIRV-Cross&nbsp;→&nbsp;<code>.mgfx</code>
                pipeline — then loads the result with a real KNI <code>Effect</code>. The
                <strong>first</strong> click downloads the ~17&nbsp;MB DXC compiler once, so it may
                pause on "Compiling…". Your shader must be a MonoGame-format effect (a
                <code>SpriteTexture</code> sampler, a <code>MainPS</code>, and a
                <code>technique</code>). Heads-up: this sample only sets the 10 built-in corpus
                parameters — a custom global such as <code>float MyAmount = 0.35;</code> is
                <em>not</em> set here (and its initializer isn't baked into the bytes), so inline
                such constants if you want them to take effect.
            </p>
        </details>
    </section>

    <section id="canvasHolder" class="stage">
        <canvas id="theCanvas" style="touch-action:none;"></canvas>
    </section>

</div>
