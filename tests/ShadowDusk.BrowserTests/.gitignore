# Phase 24 harness — generated / restored / large artifacts.
# Regenerate with: npm ci && node publish-sample.mjs && node run-harness.mjs
.publish/
captures/
diffs/
node_modules/
package-lock.json

# ShadowDusk-OWN-output validation path (--corpus=sd). Same convention as above.
# Regenerate with: node publish-sample-sd.mjs && node run-harness.mjs --corpus=sd
.publish-sd/
captures-sd/
diffs-sd/

# FAITHFUL in-browser-compile render proof (Phase 23 M3, --corpus=faithful).
# Regenerate with: node publish-sample-faithful.mjs && node run-harness.mjs --corpus=faithful
# (reuses references-sd/; RESULTS-FAITHFUL.md IS committed — the M3 deliverable.)
.publish-faithful/
captures-faithful/
diffs-faithful/

# KNI HiDef / WebGL2 path (Phase 33 / issue #7, --corpus=sd-hidef). Reuses
# .publish-sd/ + references-sd/; only its captures/diffs are HiDef-specific.
# Regenerate with: node publish-sample-sd-hidef.mjs && node run-harness.mjs --corpus=sd-hidef
captures-sd-hidef/
diffs-sd-hidef/
# Scratch dir from a one-off publish capability probe (not part of the harness).
.publish-hidef-probe/

# Phase 4.1 vkd3d->WASM byte-identity gate scratch (desktop ground-truth captures).
# Regenerate with: node node-test-vkd3d-wasm.mjs (npm run vkd3d-gate)
.vkd3d-gate/

# Phase 4.1 G2 real-browser DX/FNA byte-identity gate publish dir.
# Regenerate with: node browser-vkd3d-gate.mjs (npm run vkd3d-browser-gate)
# RESULTS-VKD3D-BROWSER.md IS committed — the G2 deliverable.
.publish-vkd3d/

# references[-sd]/*.png ARE committed: small, deterministic desktop renders that
# the harness diffs against. RESULTS[-SD].md IS committed: the Task-1c deliverable.
# RESULTS-SD-HIDEF-REPRO.md (RED) and RESULTS-SD-HIDEF.md (GREEN) ARE committed:
