# Build output
bin/
obj/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/

# Native tool downloads (restored by tools/restore.sh / tools/restore.ps1)
tools/dxc/
tools/spirv-cross/
# vkd3d-shader DXBC backend native lib — restored, not checked in (the headers
# alongside it are kept for binding reference; only the binary is ignored).
tools/vkd3d/*.dll
tools/vkd3d/*.so
tools/vkd3d/*.so.*
tools/vkd3d/*.dylib

# MGCB compiled content output (XNB wrappers — not the raw .mgfx golden files)
*.xnb
*.mgcb.log
Content/bin/
Content/obj/

# dotnet local tool cache
.dotnet/

# Visual Studio / VS Code / Rider
.vs/
.vscode/
.idea/
*.user
*.suo
*.userprefs

# OS
.DS_Store
Thumbs.db

# Test results
TestResults/
coverage/

# Validation render outputs (regenerated by the validation harness — not source)
validation/output/
validation/output-dx/

# Python
__pycache__/
*.pyc
*.pyo

# Claude Code agent worktrees (temporary, not for source control)
.claude/worktrees/
artifacts/
