# Build output
bin/
obj/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/

# Native tool downloads (restored by tools/restore.sh / tools/restore.ps1)
tools/dxc/
tools/spirv-cross/
# vkd3d-shader DXBC backend native lib — restored, not checked in (the headers
# alongside it are kept for binding reference; only the binary is ignored).
tools/vkd3d/*.dll
tools/vkd3d/*.so
tools/vkd3d/*.so.*
tools/vkd3d/*.dylib

# WASM build scratch: emsdk (~600 MB), the SPIRV-Cross + DXC source checkouts,
# and intermediate build trees. Ignored by default — BUT the durable Phase 23 M0
# deliverables under .wasm-build/ are force-committed (git add -f) past this rule
# so the build is reproducible and the faithful-DXC gates run from a clean clone:
# the build scripts (build-dxc-wasm.ps1, Invoke-DxcWasmBuild.ps1, ninja-dxcompiler.ps1,
# dxc-wasm-glue.cpp, dxc-wasm-patches.txt), the report (DXC-WASM-BUILD.md), the
# byte-identity gates (node-test-dxc-{wasm,shim}.mjs), the desktop SPIR-V oracle
# (corpus-spirv/, dxc-corpus-probe/), AND the built module dxc-wasm-out/dxcompiler.{js,wasm}
# (~17.4 MB) are all tracked. The heavy emsdk/dxc-src/spirv-cross-src checkouts are not.
.wasm-build/

# The Slang HLSL->SPIR-V WASM module (~21 MB) for samples/ShaderFiddle.Web is a
# prebuilt official release asset — restored, not committed (see
# samples/ShaderFiddle.Web/wwwroot/slang/RESTORE.md). Its small loader (.js/.d.ts)
# IS committed. The SPIRV-Cross wasm under wwwroot/spirv-cross/ IS committed
# (no prebuilt exists and it's only ~2.1 MB).
samples/ShaderFiddle.Web/wwwroot/slang/slang-wasm.wasm

# The FAITHFUL pinned DXC->WASM module (~17.4 MB) — the PRODUCT in-browser
# HLSL->SPIR-V frontend (Phase 23, Option A). Only THIS package-wwwroot COPY is
# ignored: it is restored before build/pack by copying the committed source-of-truth
# at .wasm-build/dxc-wasm-out/dxcompiler.wasm (see src/ShadowDusk.Wasm/wwwroot/dxc/RESTORE.md
# + tools/restore.* Restore-DxcWasm). Because the source is committed, a clean clone
# needs only a copy (no rebuild). The small faithful shim
# (src/ShadowDusk.Wasm/wwwroot/shadowdusk-dxc.js) and the emscripten loader
# (dxc/dxcompiler.js, ~54 KB) ARE committed here too.
src/ShadowDusk.Wasm/wwwroot/dxc/dxcompiler.wasm

# MGCB compiled content output (XNB wrappers — not the raw .mgfx golden files)
*.xnb
*.mgcb.log
Content/bin/
Content/obj/

# dotnet local tool cache
.dotnet/

# Visual Studio / VS Code / Rider
.vs/
.vscode/
.idea/
*.user
*.suo
*.userprefs

# OS
.DS_Store
Thumbs.db

# Test results
TestResults/
coverage/

# Validation render outputs (regenerated by the validation harness — not source)
validation/output/
validation/output-dx/

# Python
__pycache__/
*.pyc
*.pyo

# Claude Code agent worktrees (temporary, not for source control)
.claude/worktrees/
artifacts/
